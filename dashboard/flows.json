        "id": "fc0de2cc6c206759",
        "type": "function",
        "z": "0fb6c417c00b04d3",
        "name": "reset",
        "func": "flow.set(\"stones\", []);\nflow.set(\"history\", []);\nflow.set(\"board\", null);\n\nlet boardMsg = {\n    payload: []\n};\n\nlet historyMsg = {\n    payload: \"<b>Move History</b><br>No moves yet.\"\n};\n\nlet playerMsg = {\n    payload: \"-\"\n};\n\nlet stepMsg = {\n    payload: 0\n};\n\nlet positionMsg = {\n    payload: \"-\"\n};\n\nlet winnerMsg = {\n    payload: \"No winner yet\"\n};\n\nnode.status({\n    fill: \"blue\",\n    shape: \"dot\",\n    text: \"game reset\"\n});\n\nreturn [\n    boardMsg,\n    historyMsg,\n    playerMsg,\n    stepMsg,\n    positionMsg,\n    winnerMsg\n];",
