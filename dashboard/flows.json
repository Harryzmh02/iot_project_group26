    {
        "id": "1e999f8c13397435",
        "type": "function",
        "z": "0fb6c417c00b04d3",
        "name": "Gomoku Board",
        "func": "let stones = flow.get(\"stones\") || [];\n\nlet row = Number(msg.payload.row);\nlet col = Number(msg.payload.column);\nlet player = String(msg.payload.player).trim().toLowerCase();\nlet moveNumber = Number(msg.payload.move_number);\n\nif (row >= 1 && row <= 15 && col >= 1 && col <= 15) {\n    stones = stones.filter(s => !(s.row === row && s.col === col));\n\n    stones.push({\n        row: row,\n        col: col,\n        player: player,\n        move_number: moveNumber\n    });\n}\n\nflow.set(\"stones\", stones);\n\n\n// -----------------------------\n// Winner detection\n// -----------------------------\nfunction checkWinner(stones) {\n    const directions = [\n        [0, 1],   // horizontal\n        [1, 0],   // vertical\n        [1, 1],   // diagonal down-right\n        [1, -1]   // diagonal down-left\n    ];\n\n    const stoneSet = new Set();\n\n    for (let s of stones) {\n        stoneSet.add(`${s.player}-${s.row}-${s.col}`);\n    }\n\n    for (let s of stones) {\n        for (let [dr, dc] of directions) {\n            let count = 1;\n\n            // forward direction\n            let r = s.row + dr;\n            let c = s.col + dc;\n\n            while (stoneSet.has(`${s.player}-${r}-${c}`)) {\n                count++;\n                r += dr;\n                c += dc;\n            }\n\n            // backward direction\n            r = s.row - dr;\n            c = s.col - dc;\n\n            while (stoneSet.has(`${s.player}-${r}-${c}`)) {\n                count++;\n                r -= dr;\n                c -= dc;\n            }\n\n            if (count >= 5) {\n                return s.player;\n            }\n        }\n    }\n\n    return null;\n}\n\nlet winner = checkWinner(stones);\n\nnode.status({\n    fill: winner ? \"red\" : \"green\",\n    shape: \"dot\",\n    text: winner ? \"winner: \" + winner : \"stones: \" + stones.length\n});\n\n\n// Output 1: board\nlet boardMsg = {\n    payload: stones\n};\n\n// Output 2: winner text\nlet winnerMsg = {\n    payload: winner ? winner : \"No winner yet\"\n};\n\nreturn [boardMsg, winnerMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 260,
        "wires": [
            [
                "18b5fc5996b94eef"
            ],
            [
                "77e9d13125cfe53d"
            ]
        ]
    },
    {
        "id": "18b5fc5996b94eef",
        "type": "ui_template",
        "z": "0fb6c417c00b04d3",
        "group": "7b301a6c6054650d",
        "name": "",
        "order": 3,
        "width": 0,
        "height": 0,
        "format": "<style>\n    .gomoku-wrapper {\n        width: 100%;\n        overflow: hidden;\n        padding: 10px;\n    }\n\n    .gomoku-board {\n        position: relative;\n        width: 330px;\n        height: 330px;\n        background-color: #d9a441;\n        border: 2px solid #5c3a00;\n        box-sizing: border-box;\n    }\n\n    .board-line {\n        position: absolute;\n        background: #5c3a00;\n    }\n\n    .horizontal {\n        height: 1px;\n        width: 252px;\n        left: 39px;\n    }\n\n    .vertical {\n        width: 1px;\n        height: 252px;\n        top: 39px;\n    }\n\n    .stone {\n        position: absolute;\n        width: 15px;\n        height: 15px;\n        border-radius: 50%;\n        transform: translate(-50%, -50%);\n        z-index: 10;\n    }\n\n    .black-stone {\n        background: black;\n    }\n\n    .white-stone {\n        background: white;\n        border: 1px solid black;\n    }\n</style>\n\n<div class=\"gomoku-wrapper\">\n    <div class=\"gomoku-board\">\n\n        <div ng-repeat=\"n in [].constructor(15) track by $index\" class=\"board-line horizontal\"\n            ng-style=\"{ top: (39 + $index * 18) + 'px' }\">\n        </div>\n\n        <div ng-repeat=\"n in [].constructor(15) track by $index\" class=\"board-line vertical\"\n            ng-style=\"{ left: (39 + $index * 18) + 'px' }\">\n        </div>\n\n        <div ng-repeat=\"stone in msg.payload track by $index\" class=\"stone\" ng-class=\"{\n                'black-stone': stone.player === 'black',\n                'white-stone': stone.player === 'white'\n             }\" ng-style=\"{\n                left: (39 + (stone.col - 1) * 18) + 'px',\n                top: (39 + (stone.row - 1) * 18) + 'px'\n             }\">\n        </div>\n\n    </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 640,
        "y": 260,
        "wires": [
            []
        ]
    },
    {
        "id": "4aaa3e7fc681a9ba",
        "type": "function",
        "z": "0fb6c417c00b04d3",
        "name": "history",
        "func": "let history = flow.get(\"history\") || [];\n\nhistory.push({\n    move: msg.payload.move_number,\n    player: msg.payload.player,\n    position: \"Row \" + msg.payload.row + \", Col \" + msg.payload.column\n});\n\nflow.set(\"history\", history);\n\nmsg.payload = history\n    .map(item => \n        \"Move \" + item.move + \": \" + item.player + \" at \" + item.position\n    )\n    .join(\"<br>\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
